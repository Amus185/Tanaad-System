{
  "name": "tanaad-cloud",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --d1 DB",
    "db:migrate": "wrangler d1 execute tanaad-db --file=migrations/0001_initial_schema.sql",
    "db:migrate:local": "wrangler d1 execute tanaad-db --local --file=migrations/0001_initial_schema.sql",
    "db:seed": "wrangler d1 execute tanaad-db --file=migrations/0002_seed.sql",
    "db:seed:local": "wrangler d1 execute tanaad-db --local --file=migrations/0002_seed.sql"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "wrangler": "^3.0.0"
  }
}
